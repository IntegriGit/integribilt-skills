{
  "name": "litellm-bundle",
  "description": "IntegriBilt LiteLLM / lang-family observability + framework skills for the dedicated LiteLLM/lang ops employee(s).",
  "owner": "IntegriBilt",
  "litellmGateway": "http://192.168.254.2:4000",
  "repo": "IntegriGit/integribilt-skills",
  "skills": [
    { "name": "langfuse",              "localPath": "../langfuse",              "repoRef": "IntegriGit/integribilt-skills/langfuse" },
    { "name": "langsmith",             "localPath": "../langsmith",             "repoRef": "IntegriGit/integribilt-skills/langsmith" },
    { "name": "langtrace",             "localPath": "../langtrace",             "repoRef": "IntegriGit/integribilt-skills/langtrace" },
    { "name": "langgraph",             "localPath": "../langgraph",             "repoRef": "IntegriGit/integribilt-skills/langgraph" },
    { "name": "langchain",             "localPath": "../langchain",             "repoRef": "IntegriGit/integribilt-skills/langchain" },
    { "name": "litellm-skill-manager", "localPath": "../litellm-skill-manager", "repoRef": "IntegriGit/integribilt-skills/litellm-skill-manager" }
  ],
  "paperclip": {
    "assignTo": "<dedicated litellm/lang employee agent id(s) — set PAPERCLIP_AGENT_IDS>",
    "importPreference": "repoRef"
  }
}
